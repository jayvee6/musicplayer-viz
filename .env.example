# Copy this file to `.env` (which is gitignored) and fill in real values.
# None of these values should ever be committed.

# ─── Spotify (PKCE, client-side) ─────────────────────────────────────────────
# client_id is NOT a secret under PKCE, but still don't commit it.
# Get it from https://developer.spotify.com/dashboard → your app → Settings.
SPOTIFY_CLIENT_ID=

# ─── Apple Music (MusicKit JS) ───────────────────────────────────────────────
# Generate these at developer.apple.com → Certificates, Identifiers & Profiles → Keys
# (create a new key with MusicKit enabled; download the .p8 file ONCE).
#
# APPLE_PRIVATE_KEY_PATH points to the .p8 file. Put it OUTSIDE the repo or in
# a gitignored subdirectory (e.g. ./secrets/). The file never ships to clients.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./secrets/AuthKey_XXXXXXXXXX.p8

# How long each signed developer token is valid (seconds). Default 7200 = 2h.
# Apple's hard maximum is 6 months; keep this short so leaked tokens expire fast.
APPLE_TOKEN_TTL_SEC=7200
